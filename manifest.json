{
  "manifest_version": 2,
  "name": "YouTube PLUS",
  "version": "1.2",
  "description": "Sets a forced default video quality and enforces sharp corners.",
  "browser_specific_settings": {
    "gecko": {
      "id": "youtube-plus@nothank.you",
      "data_collection_permissions": {
        "required": [ "none" ]
      }
    }
  },
  "permissions": [
    "storage",
    "*://*.youtube.com/*",
    "*://*.music.youtube.com/*"
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Set YouTube Quality",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.music.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  }
}
